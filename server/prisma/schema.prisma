generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())

  email      String      @unique
  password   String

  createdAt  DateTime    @default(now())

  appConfigs AppConfig[]
  records    Record[]
}

model AppConfig {
  id         String   @id @default(cuid())

  name       String

  config     Json

  userId     String

  user       User @relation(fields: [userId], references: [id])

  createdAt  DateTime @default(now())
}

model Record {
  id          String   @id @default(cuid())

  entityName  String

  data        Json

  userId      String

  user        User @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}